<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تم التفعيل بنجاح</title>
  <style>
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      font-family: Arial, sans-serif;
      background-color: #1f1f21;
      margin: 0;
      padding: 0;
    }
    .container {
      text-align: center;
      background: #302f2f;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5);
      max-width: 400px;
      width: 100%;
    }
    .profile-pic {
      border-radius: 50%;
      width: 120px;
      height: 120px;
      border: 5px solid #4CAF50;
    }
    .username {
      font-size: 24px;
      font-weight: bold;
      margin: 10px 0;
      color: #c4c4c4;
    }
    .success-message {
      color: #4CAF50;
      font-size: 18px;
      margin: 10px 0;
    }
    .activated-time {
      font-size: 14px;
      color: #c4c4c4;
    }
  </style>
</head>
<body>
  <div class="container">
    <img class="profile-pic" src="<%= user.avatarUrl %>" alt="صورة المستخدم">
    <div class="username"><%= user.username %></div>
    <div class="success-message">🎉 تم تفعيل حسابك بنجاح!</div>
    <div class="activated-time" id="activation-time"></div>
  </div>

  <script>
    const activationTime = new Date("<%= user.activationDate %>");
    document.getElementById('activation-time').textContent = 
      "تم التفعيل بتاريخ: " + activationTime.toLocaleDateString("ar-EG") + 
      " الساعة " + activationTime.toLocaleTimeString("ar-EG");
  </script>
</body>
</html>
